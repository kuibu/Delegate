{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": false,
    "baseUrl": ".",
    "paths": {
      "@delegate/domain": ["packages/domain/src/index.ts"],
      "@delegate/runtime": ["packages/runtime/src/index.ts"],
      "@delegate/registry": ["packages/registry/src/index.ts"],
      "@delegate/openviking": ["packages/openviking/src/index.ts"],
      "@delegate/web-data": ["packages/web-data/src/index.ts"],
      "@delegate/web-ui": ["packages/web-ui/src/index.ts"]
    }
  }
}
