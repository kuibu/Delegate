generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Channel {
  PRIVATE_CHAT
  GROUP_MENTION
  GROUP_REPLY
  CHANNEL_ENTRY
}

enum PricingPlanType {
  FREE
  PASS
  DEEP_HELP
  SPONSOR
}

enum AudienceRole {
  LEAD
  PARTNER
  CANDIDATE
  MEDIA
  COMMUNITY
  OTHER
}

enum ContactStage {
  NEW
  QUALIFIED
  PENDING_PAYMENT
  WAITING_ON_OWNER
  WON
  LOST
}

enum GroupActivation {
  MENTION_ONLY
  REPLY_OR_MENTION
  ALWAYS
}

enum SkillPackSource {
  BUILTIN
  OWNER_UPLOAD
  CLAWHUB
}

enum HandoffStatus {
  OPEN
  REVIEWING
  ACCEPTED
  DECLINED
  CLOSED
}

enum InvoiceStatus {
  PENDING
  PAID
  FULFILLED
  REFUNDED
  FAILED
  CANCELED
}

enum EventType {
  MESSAGE_RECEIVED
  MESSAGE_ANSWERED
  MODEL_CONTEXT_ASSEMBLED
  MODEL_REPLY_COMPLETED
  INTAKE_STARTED
  INTAKE_SUBMITTED
  MATERIAL_SENT
  PAYMENT_INVOICE_CREATED
  PAYMENT_CONFIRMED
  PAYMENT_REFUNDED
  HANDOFF_PREPARED
  HANDOFF_REQUESTED
  HANDOFF_RESOLVED
  COMPUTE_SESSION_REQUESTED
  COMPUTE_SESSION_STARTED
  COMPUTE_SESSION_HEARTBEAT
  COMPUTE_SESSION_TERMINATED
  TOOL_EXECUTION_REQUESTED
  TOOL_EXECUTION_BLOCKED
  TOOL_EXECUTION_COMPLETED
  APPROVAL_REQUESTED
  APPROVAL_RESOLVED
  ARTIFACT_STORED
  BROWSER_NAVIGATION_RECORDED
  BROWSER_SESSION_CLOSED
  BILLING_LEDGER_RECORDED
  WORKFLOW_ENQUEUED
  WORKFLOW_COMPLETED
  WORKFLOW_FAILED
}

enum CapabilityKind {
  EXEC
  READ
  WRITE
  PROCESS
  BROWSER
  MCP
}

enum McpTransportKind {
  STREAMABLE_HTTP
}

enum CapabilityPlanTier {
  PASS
  DEEP_HELP
}

enum PolicyDecision {
  ALLOW
  ASK
  DENY
}

enum ComputeSessionStatus {
  REQUESTED
  STARTING
  RUNNING
  IDLE
  STOPPING
  COMPLETED
  FAILED
  EXPIRED
}

enum ComputeLeaseStatus {
  REQUESTED
  READY
  RELEASING
  RELEASED
  FAILED
}

enum ToolExecutionStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  BLOCKED
  CANCELED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum ArtifactKind {
  STDOUT
  STDERR
  FILE
  ARCHIVE
  SCREENSHOT
  JSON
  TRACE
}

enum BrowserTransportKind {
  PLAYWRIGHT
  OPENAI_COMPUTER
  CLAUDE_COMPUTER_USE
}

enum BrowserSessionStatus {
  ACTIVE
  FAILED
  CLOSED
}

enum BrowserNavigationStatus {
  SUCCEEDED
  FAILED
}

enum WorkflowKind {
  HANDOFF_FOLLOW_UP
  APPROVAL_EXPIRATION
}

enum WorkflowStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELED
}

enum WorkflowEngine {
  LOCAL_RUNNER
  TEMPORAL
}

enum LedgerEntryKind {
  MODEL_USAGE
  COMPUTE_MINUTES
  STORAGE_BYTES
  ARTIFACT_EGRESS
  BROWSER_MINUTES
  PLAN_DEBIT
  SPONSOR_CREDIT
}

enum ComputeRequestedBy {
  SYSTEM
  OWNER
  AUDIENCE
}

enum ComputeRunnerType {
  DOCKER
  VM
}

enum ComputeNetworkMode {
  NO_NETWORK
  ALLOWLIST
  FULL
}

enum ComputeFilesystemMode {
  WORKSPACE_ONLY
  READ_ONLY_WORKSPACE
  EPHEMERAL_FULL
}

model Owner {
  id              String           @id @default(cuid())
  telegramUserId  String?          @unique
  displayName     String
  handle          String?
  timezone        String           @default("UTC")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  wallet          Wallet?
  representatives Representative[]
}

model Wallet {
  id                String   @id @default(cuid())
  ownerId           String   @unique
  balanceCredits    Int      @default(0)
  sponsorPoolCredit Int      @default(0)
  starsBalance      Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  owner             Owner    @relation(fields: [ownerId], references: [id])
}

model Representative {
  id                String            @id @default(cuid())
  ownerId           String
  slug              String            @unique
  displayName       String
  roleSummary       String
  tone              String
  avatarUrl         String?
  publicMode        Boolean           @default(true)
  groupModeEnabled  Boolean           @default(false)
  groupActivation   GroupActivation   @default(REPLY_OR_MENTION)
  humanInLoop       Boolean           @default(true)
  languages         Json
  freeReplyLimit    Int               @default(4)
  freeScope         Json
  paywalledIntents  Json
  handoffWindowHours Int              @default(24)
  freeMonthlyCredit Int               @default(100)
  handoffPrompt     String
  allowedSkills     Json
  actionGate        Json
  openvikingEnabled Boolean           @default(false)
  openvikingAgentId String?
  openvikingAutoRecall Boolean        @default(true)
  openvikingAutoCapture Boolean       @default(true)
  openvikingCaptureMode String        @default("semantic")
  openvikingRecallLimit Int           @default(6)
  openvikingRecallScoreThreshold Float @default(0.01)
  openvikingTargetUri String?
  openvikingLastSyncAt DateTime?
  openvikingLastSyncStatus String?
  openvikingLastSyncError String?
  openvikingLastSyncItemCount Int?
  computeEnabled     Boolean           @default(false)
  computeDefaultPolicyMode PolicyDecision @default(ASK)
  computeBaseImage   String            @default("debian:bookworm-slim")
  computeMaxSessionMinutes Int         @default(15)
  computeAutoApproveBudgetCents Int    @default(0)
  computeArtifactRetentionDays Int     @default(14)
  computeNetworkMode ComputeNetworkMode @default(NO_NETWORK)
  computeNetworkAllowlist String[]     @default([])
  computeFilesystemMode ComputeFilesystemMode @default(WORKSPACE_ONLY)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  owner             Owner             @relation(fields: [ownerId], references: [id])
  capabilityProfiles CapabilityPolicyProfile[]
  computeSessions   ComputeSession[]
  conversations     Conversation[]
  contextSyncJobs   RepresentativeContextSync[]
  contacts          Contact[]
  commitTraces      ConversationCommitTrace[]
  events            EventAudit[]
  handoffRequests   HandoffRequest[]
  artifacts         Artifact[]
  approvalRequests  ApprovalRequest[]
  intakeSubmissions IntakeSubmission[]
  invoices          Invoice[]
  ledgerEntries     LedgerEntry[]
  browserSessions   BrowserSession[]
  browserNavigations BrowserNavigation[]
  knowledgePack     KnowledgePack?
  memoryRecords     OpenVikingMemoryRecord[]
  pricingPlans      PricingPlan[]
  recallTraces      ConversationRecallTrace[]
  skillPackLinks    RepresentativeSkillPack[]
  mcpBindings       RepresentativeMcpBinding[]
  chatSessions      ChatSession[]
  workflowRuns      WorkflowRun[]
}

model KnowledgePack {
  id               String         @id @default(cuid())
  representativeId String         @unique
  identitySummary  String
  faq              Json
  materials        Json
  policies         Json
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  representative   Representative @relation(fields: [representativeId], references: [id])
}

model PricingPlan {
  id                     String          @id @default(cuid())
  representativeId       String
  type                   PricingPlanType
  name                   String
  starsAmount            Int
  summary                String
  includedReplies        Int
  includesPriorityHandoff Boolean       @default(false)
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  representative         Representative  @relation(fields: [representativeId], references: [id])
}

model SkillPack {
  id                  String                   @id @default(cuid())
  source              SkillPackSource
  slug                String
  displayName         String
  summary             String
  version             String?
  sourceUrl           String?
  ownerHandle         String?
  verificationTier    String?
  capabilityTags      Json
  executesCode        Boolean                  @default(false)
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  representativeLinks RepresentativeSkillPack[]

  @@unique([source, slug])
}

model RepresentativeSkillPack {
  id               String          @id @default(cuid())
  representativeId String
  skillPackId      String
  enabled          Boolean         @default(true)
  installStatus    String          @default("available")
  installedVersion String?
  installedAt      DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  representative   Representative  @relation(fields: [representativeId], references: [id])
  skillPack        SkillPack       @relation(fields: [skillPackId], references: [id])
  mcpBindings      RepresentativeMcpBinding[]

  @@unique([representativeId, skillPackId])
}

model RepresentativeMcpBinding {
  id                           String                  @id @default(cuid())
  representativeId             String
  representativeSkillPackLinkId String?
  slug                         String
  displayName                  String
  description                  String?
  serverUrl                    String
  transportKind                McpTransportKind        @default(STREAMABLE_HTTP)
  allowedToolNames             Json
  defaultToolName              String?
  enabled                      Boolean                 @default(true)
  approvalRequired             Boolean                 @default(true)
  createdAt                    DateTime                @default(now())
  updatedAt                    DateTime                @updatedAt
  representative               Representative          @relation(fields: [representativeId], references: [id])
  representativeSkillPackLink  RepresentativeSkillPack? @relation(fields: [representativeSkillPackLinkId], references: [id])
  toolExecutions               ToolExecution[]

  @@unique([representativeId, slug])
  @@index([representativeId, enabled, createdAt])
}

model Contact {
  id               String            @id @default(cuid())
  representativeId String
  telegramUserId   String
  username         String?
  displayName      String?
  role             AudienceRole      @default(OTHER)
  stage            ContactStage      @default(NEW)
  isPaid           Boolean           @default(false)
  source           String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  lastSeenAt       DateTime          @default(now())
  representative   Representative    @relation(fields: [representativeId], references: [id])
  commitTraces     ConversationCommitTrace[]
  conversations    Conversation[]
  events           EventAudit[]
  handoffRequests  HandoffRequest[]
  intakeSubmissions IntakeSubmission[]
  invoices         Invoice[]
  memoryRecords    OpenVikingMemoryRecord[]
  computeSessions  ComputeSession[]
  artifacts        Artifact[]
  approvalRequests ApprovalRequest[]
  ledgerEntries    LedgerEntry[]
  browserSessions  BrowserSession[]
  browserNavigations BrowserNavigation[]
  recallTraces     ConversationRecallTrace[]
  computeTrustTier String?
  lastApprovalGrantedAt DateTime?
  workflowRuns     WorkflowRun[]

  @@unique([representativeId, telegramUserId])
}

model Conversation {
  id               String            @id @default(cuid())
  representativeId String
  contactId        String
  telegramChatId   String
  channel          Channel
  state            String            @default("ACTIVE")
  collectorState   Json?
  freeRepliesUsed  Int               @default(0)
  passUnlockedAt   DateTime?
  deepHelpUnlockedAt DateTime?
  activeComputeSessionId String?
  computeBudgetRemainingCredits Int?
  lastComputeAt    DateTime?
  openvikingSessionId String?        @unique
  openvikingSessionKey String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  lastMessageAt    DateTime          @default(now())
  commitTraces     ConversationCommitTrace[]
  computeSessions  ComputeSession[]
  representative   Representative    @relation(fields: [representativeId], references: [id])
  contact          Contact           @relation(fields: [contactId], references: [id])
  recallTraces     ConversationRecallTrace[]
  turns            ConversationTurn[]
  events           EventAudit[]
  artifacts        Artifact[]
  approvalRequests ApprovalRequest[]
  handoffRequests  HandoffRequest[]
  intakeSubmissions IntakeSubmission[]
  invoices         Invoice[]
  ledgerEntries    LedgerEntry[]
  browserSessions  BrowserSession[]
  browserNavigations BrowserNavigation[]
  workflowRuns     WorkflowRun[]

  @@unique([representativeId, telegramChatId, contactId])
}

model ChatSession {
  id               String         @id @default(cuid())
  telegramChatId   String         @unique
  telegramUserId   String
  representativeId String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  representative   Representative @relation(fields: [representativeId], references: [id])
}

model ConversationTurn {
  id             String       @id @default(cuid())
  conversationId String
  direction      String
  messageText    String
  intent         String?
  summary        String?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
}

model IntakeSubmission {
  id                 String          @id @default(cuid())
  representativeId   String
  contactId          String
  conversationId     String?
  requestType        String
  payload            Json
  priorityScore      Int             @default(0)
  recommendedNextStep String
  createdAt          DateTime        @default(now())
  representative     Representative  @relation(fields: [representativeId], references: [id])
  contact            Contact         @relation(fields: [contactId], references: [id])
  conversation       Conversation?   @relation(fields: [conversationId], references: [id])
  handoffRequests    HandoffRequest[]
}

model HandoffRequest {
  id                   String           @id @default(cuid())
  representativeId     String
  contactId            String
  conversationId       String?
  intakeSubmissionId   String?
  reason               String
  summary              String
  recommendedPriority  Int              @default(0)
  recommendedOwnerAction String
  status               HandoffStatus    @default(OPEN)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  representative       Representative   @relation(fields: [representativeId], references: [id])
  contact              Contact          @relation(fields: [contactId], references: [id])
  conversation         Conversation?    @relation(fields: [conversationId], references: [id])
  intakeSubmission     IntakeSubmission? @relation(fields: [intakeSubmissionId], references: [id])
  workflowRuns         WorkflowRun[]

  @@index([representativeId, status, createdAt])
}

model Invoice {
  id                      String          @id @default(cuid())
  representativeId        String
  contactId               String
  conversationId          String?
  planType                PricingPlanType
  title                   String
  payload                 String          @unique
  starsAmount             Int
  invoiceLink             String?
  telegramPaymentChargeId String?
  providerPaymentChargeId String?
  status                  InvoiceStatus   @default(PENDING)
  paidAt                  DateTime?
  refundedAt              DateTime?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  representative          Representative  @relation(fields: [representativeId], references: [id])
  contact                 Contact         @relation(fields: [contactId], references: [id])
  conversation            Conversation?   @relation(fields: [conversationId], references: [id])

  @@index([representativeId, status, createdAt])
}

model EventAudit {
  id               String          @id @default(cuid())
  representativeId String
  contactId        String?
  conversationId   String?
  type             EventType
  payload          Json
  createdAt        DateTime        @default(now())
  representative   Representative  @relation(fields: [representativeId], references: [id])
  contact          Contact?        @relation(fields: [contactId], references: [id])
  conversation     Conversation?   @relation(fields: [conversationId], references: [id])
}

model CapabilityPolicyProfile {
  id                 String                @id @default(cuid())
  representativeId   String
  name               String
  isDefault          Boolean               @default(true)
  isManaged          Boolean               @default(false)
  managedSource      String?
  precedence         Int                   @default(0)
  defaultDecision    PolicyDecision        @default(ASK)
  maxSessionMinutes  Int                   @default(15)
  maxParallelSessions Int                  @default(1)
  maxCommandSeconds  Int                   @default(30)
  artifactRetentionDays Int                @default(14)
  networkMode        ComputeNetworkMode    @default(NO_NETWORK)
  networkAllowlist   String[]              @default([])
  filesystemMode     ComputeFilesystemMode @default(WORKSPACE_ONLY)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  representative     Representative        @relation(fields: [representativeId], references: [id])
  computeSessions    ComputeSession[]
  rules              CapabilityPolicyRule[]

  @@index([representativeId, isDefault])
}

model CapabilityPolicyRule {
  id                   String                @id @default(cuid())
  profileId            String
  capability           CapabilityKind
  decision             PolicyDecision
  commandPattern       String?
  pathPattern          String?
  domainPattern        String?
  channelCondition     Channel?
  requiredPlanTier     CapabilityPlanTier?
  maxCostCents         Int?
  requiresPaidPlan     Boolean               @default(false)
  requiresHumanApproval Boolean              @default(false)
  priority             Int                   @default(0)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  profile              CapabilityPolicyProfile @relation(fields: [profileId], references: [id])

  @@index([profileId, capability, priority])
}

model ComputeSession {
  id                 String               @id @default(cuid())
  representativeId   String
  contactId          String?
  conversationId     String?
  policyProfileId    String?
  requestedBy        ComputeRequestedBy
  status             ComputeSessionStatus @default(REQUESTED)
  leaseStatus        ComputeLeaseStatus   @default(REQUESTED)
  runnerLeaseId      String?
  containerId        String?
  runnerType         ComputeRunnerType    @default(DOCKER)
  baseImage          String
  leaseTokenHash     String               @unique
  leaseAcquiredAt    DateTime?
  leaseLastUsedAt    DateTime?
  leaseReleasedAt    DateTime?
  startedAt          DateTime?
  lastHeartbeatAt    DateTime?
  expiresAt          DateTime?
  endedAt            DateTime?
  failureReason      String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  representative     Representative       @relation(fields: [representativeId], references: [id])
  contact            Contact?             @relation(fields: [contactId], references: [id])
  conversation       Conversation?        @relation(fields: [conversationId], references: [id])
  policyProfile      CapabilityPolicyProfile? @relation(fields: [policyProfileId], references: [id])
  toolExecutions     ToolExecution[]
  browserSession     BrowserSession?
  artifacts          Artifact[]
  approvalRequests   ApprovalRequest[]
  ledgerEntries      LedgerEntry[]

  @@index([representativeId, status, createdAt])
  @@index([contactId, createdAt])
  @@index([conversationId, createdAt])
}

model ToolExecution {
  id               String              @id @default(cuid())
  sessionId        String
  mcpBindingId     String?
  capability       CapabilityKind
  status           ToolExecutionStatus @default(QUEUED)
  requestedCommand String?
  requestedPath    String?
  requestPayload   Json?
  workingDirectory String?
  policyDecision   PolicyDecision?
  approvalRequestId String?
  startedAt        DateTime?
  finishedAt       DateTime?
  exitCode         Int?
  cpuMs            Int?
  wallMs           Int?
  bytesRead        Int?
  bytesWritten     Int?
  createdAt        DateTime            @default(now())
  session          ComputeSession      @relation(fields: [sessionId], references: [id])
  mcpBinding       RepresentativeMcpBinding? @relation(fields: [mcpBindingId], references: [id])
  artifacts        Artifact[]
  browserNavigation BrowserNavigation?

  @@index([sessionId, createdAt])
  @@index([status, createdAt])
  @@index([mcpBindingId, createdAt])
}

model ApprovalRequest {
  id                    String         @id @default(cuid())
  representativeId      String
  contactId             String?
  conversationId        String?
  sessionId             String?
  toolExecutionId       String?        @unique
  status                ApprovalStatus @default(PENDING)
  reason                String
  requestedActionSummary String
  riskSummary           String
  requestedAt           DateTime       @default(now())
  resolvedAt            DateTime?
  resolvedBy            String?
  representative        Representative @relation(fields: [representativeId], references: [id])
  contact               Contact?       @relation(fields: [contactId], references: [id])
  conversation          Conversation?  @relation(fields: [conversationId], references: [id])
  session               ComputeSession? @relation(fields: [sessionId], references: [id])
  workflowRuns          WorkflowRun[]

  @@index([representativeId, status, requestedAt])
}

model Artifact {
  id               String          @id @default(cuid())
  representativeId String
  contactId        String?
  conversationId   String?
  sessionId        String?
  toolExecutionId  String?
  kind             ArtifactKind
  bucket           String
  objectKey        String
  mimeType         String
  sizeBytes        Int
  sha256           String
  isPinned         Boolean         @default(false)
  pinnedAt         DateTime?
  pinnedBy         String?
  downloadCount    Int             @default(0)
  lastDownloadedAt DateTime?
  retentionUntil   DateTime?
  summary          String?
  createdAt        DateTime        @default(now())
  representative   Representative  @relation(fields: [representativeId], references: [id])
  contact          Contact?        @relation(fields: [contactId], references: [id])
  conversation     Conversation?   @relation(fields: [conversationId], references: [id])
  session          ComputeSession? @relation(fields: [sessionId], references: [id])
  toolExecution    ToolExecution?  @relation(fields: [toolExecutionId], references: [id])

  @@index([representativeId, createdAt])
  @@index([sessionId, createdAt])
}

model WorkflowRun {
  id               String         @id @default(cuid())
  representativeId String
  contactId        String?
  conversationId   String?
  handoffRequestId String?
  approvalRequestId String?
  kind             WorkflowKind
  engine           WorkflowEngine @default(LOCAL_RUNNER)
  status           WorkflowStatus @default(QUEUED)
  dedupeKey        String         @unique
  queueName        String?
  externalWorkflowId String?
  scheduledAt      DateTime
  startedAt        DateTime?
  completedAt      DateTime?
  failedAt         DateTime?
  lastError        String?
  input            Json
  output           Json?
  attemptCount     Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  representative   Representative @relation(fields: [representativeId], references: [id])
  contact          Contact?       @relation(fields: [contactId], references: [id])
  conversation     Conversation?  @relation(fields: [conversationId], references: [id])
  handoffRequest   HandoffRequest? @relation(fields: [handoffRequestId], references: [id])
  approvalRequest  ApprovalRequest? @relation(fields: [approvalRequestId], references: [id])

  @@index([representativeId, scheduledAt])
  @@index([engine, status, scheduledAt])
  @@index([status, scheduledAt])
  @@index([handoffRequestId])
  @@index([approvalRequestId])
}

model BrowserSession {
  id                String               @id @default(cuid())
  representativeId  String
  contactId         String?
  conversationId    String?
  computeSessionId  String               @unique
  status            BrowserSessionStatus @default(ACTIVE)
  transportKind     BrowserTransportKind @default(PLAYWRIGHT)
  profilePath       String?
  currentUrl        String?
  currentTitle      String?
  lastToolExecutionId String?
  lastNavigationAt  DateTime?
  closedAt          DateTime?
  failureReason     String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  representative    Representative       @relation(fields: [representativeId], references: [id])
  contact           Contact?             @relation(fields: [contactId], references: [id])
  conversation      Conversation?        @relation(fields: [conversationId], references: [id])
  computeSession    ComputeSession       @relation(fields: [computeSessionId], references: [id])
  navigations       BrowserNavigation[]

  @@index([representativeId, updatedAt])
  @@index([conversationId, updatedAt])
}

model BrowserNavigation {
  id                 String                  @id @default(cuid())
  browserSessionId   String
  representativeId   String
  contactId          String?
  conversationId     String?
  toolExecutionId    String                  @unique
  status             BrowserNavigationStatus
  transportKind      BrowserTransportKind    @default(PLAYWRIGHT)
  requestedUrl       String
  finalUrl           String?
  pageTitle          String?
  textSnippet        String?
  screenshotArtifactId String?
  jsonArtifactId     String?
  errorMessage       String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  browserSession     BrowserSession          @relation(fields: [browserSessionId], references: [id])
  representative     Representative          @relation(fields: [representativeId], references: [id])
  contact            Contact?                @relation(fields: [contactId], references: [id])
  conversation       Conversation?           @relation(fields: [conversationId], references: [id])
  toolExecution      ToolExecution           @relation(fields: [toolExecutionId], references: [id])

  @@index([browserSessionId, createdAt])
  @@index([representativeId, createdAt])
}

model LedgerEntry {
  id               String          @id @default(cuid())
  representativeId String
  contactId        String?
  conversationId   String?
  sessionId        String?
  toolExecutionId  String?
  invoiceId        String?
  kind             LedgerEntryKind
  quantity         Float
  unit             String
  costCents        Int             @default(0)
  creditDelta      Int             @default(0)
  currency         String          @default("USD")
  notes            String?
  createdAt        DateTime        @default(now())
  representative   Representative  @relation(fields: [representativeId], references: [id])
  contact          Contact?        @relation(fields: [contactId], references: [id])
  conversation     Conversation?   @relation(fields: [conversationId], references: [id])
  session          ComputeSession? @relation(fields: [sessionId], references: [id])

  @@index([representativeId, createdAt])
  @@index([sessionId, createdAt])
  @@index([kind, createdAt])
}

model RepresentativeContextSync {
  id               String          @id @default(cuid())
  representativeId String
  status           String
  itemCount        Int             @default(0)
  error            String?
  startedAt        DateTime
  finishedAt       DateTime?
  createdAt        DateTime        @default(now())
  representative   Representative  @relation(fields: [representativeId], references: [id])

  @@index([representativeId, createdAt])
}

model ConversationRecallTrace {
  id               String          @id @default(cuid())
  representativeId String
  conversationId   String?
  contactId        String?
  queryText        String
  recalledUri      String
  contextType      String
  layer            String
  score            Float
  createdAt        DateTime        @default(now())
  representative   Representative  @relation(fields: [representativeId], references: [id])
  conversation     Conversation?   @relation(fields: [conversationId], references: [id])
  contact          Contact?        @relation(fields: [contactId], references: [id])

  @@index([representativeId, createdAt])
  @@index([conversationId, createdAt])
}

model ConversationCommitTrace {
  id               String          @id @default(cuid())
  representativeId String
  conversationId   String?
  contactId        String?
  sessionId        String
  sessionKey       String?
  reason           String
  status           String
  memoriesExtracted Int?
  archived         Boolean?
  error            String?
  createdAt        DateTime        @default(now())
  representative   Representative  @relation(fields: [representativeId], references: [id])
  conversation     Conversation?   @relation(fields: [conversationId], references: [id])
  contact          Contact?        @relation(fields: [contactId], references: [id])

  @@index([representativeId, createdAt])
  @@index([conversationId, createdAt])
}

model OpenVikingMemoryRecord {
  id               String          @id @default(cuid())
  representativeId String
  contactId        String?
  uri              String          @unique
  contextType      String
  scope            String
  category         String
  summary          String
  sourceKind       String
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  representative   Representative  @relation(fields: [representativeId], references: [id])
  contact          Contact?        @relation(fields: [contactId], references: [id])

  @@index([representativeId, createdAt])
  @@index([representativeId, contactId, createdAt])
}
