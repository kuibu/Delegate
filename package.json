{
  "name": "delegate",
  "private": true,
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "dev:web": "pnpm --filter @delegate/dashboard dev",
    "dev:site": "pnpm --filter @delegate/site dev",
    "dev:dashboard": "pnpm --filter @delegate/dashboard dev",
    "dev:reps": "pnpm --filter @delegate/reps dev",
    "dev:bot": "pnpm --filter @delegate/bot dev",
    "dev:compute-broker": "pnpm --filter @delegate/compute-broker dev",
    "registry:search:clawhub": "tsx scripts/clawhub-search.ts",
    "docker:up": "docker compose up -d --build",
    "docker:up:db": "docker compose up -d postgres",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:ps": "docker compose ps",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:validate": "prisma validate --schema prisma/schema.prisma",
    "db:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "db:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "pnpm db:generate && pnpm db:deploy && pnpm db:seed"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "prisma": "^6.19.2",
    "tsx": "^4.21.0",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2"
  }
}
